const express = require('express');
const crypto = require('crypto');
const app = express();

app.use(express.json());

// Clave secreta proporcionada por la red de anuncios (ej: Lootably)
const APY_SECRET_KEY = "tu_firma_secreta_aqui";

// Endpoint seguro para escuchar los pagos completados (Postback)
app.post('/api/postback/lootably', (req, res) => {
    const signature = req.headers['x-lootably-signature']; 
    const body = JSON.stringify(req.body);

    // 1. Validar firma criptográfica para evitar hackeos de saldo
    const expectedSignature = crypto
        .createHmac('sha256', APY_SECRET_KEY)
        .update(body)
        .digest('hex');

    if (signature !== expectedSignature) {
        console.warn("⚠️ [ALERTA] Firma no coincide. Petición rechazada!");
        return res.status(401).send("Firma inválida");
    }

    // 2. Extraer parámetros seguros enviados por la red
    const { userId, coins, status } = req.body;

    if (status === 'completed') {
        console.log(`✅ Acreditando ${coins} monedas al usuario ${userId}`);
        
        // 3. AQUÍ ACTUALIZAS TU BASE DE DATOS REAL (Ej: MongoDB / PostgreSQL)
        // db.users.updateOne({ id: userId }, { $inc: { coins: coins } });
    }

    res.status(200).send("Acreditado");
});

app.listen(3000, () => console.log("Servidor corriendo en puerto 3000"));
